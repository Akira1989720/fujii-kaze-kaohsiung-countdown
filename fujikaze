<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#d4ab63" />
  <meta name="description" content="2026 藤井風高雄演唱會：公開售票與演出時間雙倒數。" />
  <title>藤井風高雄演唱會倒數｜Fujii Kaze Prema World Tour</title>
  <style>
    :root {
      --paper: #f8f1e5;
      --paper-soft: #fffaf2;
      --cream: #f3e5c7;
      --honey: #d6ad66;
      --honey-soft: #e8c989;
      --ochre: #bd834f;
      --terracotta: #a66343;
      --tobacco: #784b35;
      --brown: #50382c;
      --deep: #302e29;
      --olive: #68664f;
      --olive-soft: #817d60;
      --line: rgba(100, 67, 42, 0.2);
      --line-strong: rgba(111, 73, 43, 0.34);
      --shadow: 0 18px 48px rgba(86, 57, 36, 0.16);
      --shadow-soft: 0 10px 32px rgba(86, 57, 36, 0.11);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--deep);
      background:
        radial-gradient(circle at 12% 8%, rgba(255, 246, 210, 0.88), transparent 25rem),
        radial-gradient(circle at 90% 18%, rgba(218, 176, 96, 0.38), transparent 28rem),
        radial-gradient(circle at 82% 90%, rgba(169, 99, 63, 0.24), transparent 30rem),
        linear-gradient(135deg, #e8c985 0%, #d7ae68 48%, #bf8654 100%);
      font-family: "Iowan Old Style", "Noto Serif TC", "Songti TC", "PingFang TC", "Microsoft JhengHei", serif;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.1;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.78' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.38'/%3E%3C/svg%3E");
      mix-blend-mode: multiply;
    }

    main {
      width: min(1120px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 1.8rem 0 2.2rem;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(80, 56, 44, 0.22);
      color: rgba(69, 48, 37, 0.82);
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      line-height: 1.6;
      text-transform: uppercase;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
      gap: 2rem;
      padding: clamp(4.8rem, 10vw, 8.6rem) 0 clamp(3rem, 5vw, 4rem);
    }

    .eyebrow {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 0 0 1.3rem;
      color: var(--tobacco);
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .eyebrow::before {
      content: "";
      width: 2.4rem;
      height: 1px;
      background: currentColor;
    }

    h1 {
      margin: 0;
      color: var(--brown);
      font-weight: 500;
      letter-spacing: -0.06em;
      line-height: 0.95;
    }

    .title-main,
    .title-sub { display: block; }

    .title-main { font-size: clamp(4.3rem, 11vw, 9.4rem); }

    .title-sub {
      margin-top: 0.26em;
      color: var(--tobacco);
      font-size: clamp(2.05rem, 6.1vw, 5rem);
      letter-spacing: -0.055em;
      line-height: 1.05;
    }

    .subtitle {
      margin: 1.55rem 0 0;
      color: rgba(79, 54, 40, 0.82);
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: clamp(0.71rem, 1.2vw, 0.9rem);
      font-weight: 700;
      letter-spacing: 0.17em;
      line-height: 1.9;
      text-transform: uppercase;
    }

    .hero-note {
      max-width: 15rem;
      margin: 0 0 0.25rem;
      padding-left: 1rem;
      border-left: 1px solid rgba(90, 59, 40, 0.36);
      color: rgba(75, 52, 40, 0.75);
      font-size: 0.86rem;
      letter-spacing: 0.04em;
      line-height: 1.9;
    }

    .countdown-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .countdown-card {
      position: relative;
      min-height: 21rem;
      overflow: hidden;
      padding: clamp(1.4rem, 3vw, 1.9rem);
      border: 1px solid rgba(120, 75, 53, 0.22);
      border-radius: 1rem;
      background: rgba(255, 250, 242, 0.91);
      box-shadow: var(--shadow);
      backdrop-filter: blur(15px);
    }

    .countdown-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto;
      height: 0.34rem;
      background: linear-gradient(90deg, var(--terracotta), var(--honey));
    }

    .countdown-card[data-target="concert"]::before {
      background: linear-gradient(90deg, var(--olive), var(--honey-soft));
    }

    .card-kicker {
      display: inline-flex;
      align-items: center;
      gap: 0.52rem;
      color: var(--terracotta);
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: 0.67rem;
      font-weight: 700;
      letter-spacing: 0.17em;
      line-height: 1.55;
      text-transform: uppercase;
    }

    [data-target="concert"] .card-kicker { color: var(--olive); }

    .status-dot {
      width: 0.4rem;
      height: 0.4rem;
      border-radius: 50%;
      background: currentColor;
    }

    .countdown-card h2 {
      margin: 1rem 0 0;
      color: var(--brown);
      font-size: clamp(1.62rem, 3vw, 2.2rem);
      font-weight: 600;
      letter-spacing: 0.04em;
    }

    .datetime {
      margin: 0.52rem 0 1.55rem;
      color: var(--olive-soft);
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: 0.73rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      line-height: 1.8;
      text-transform: uppercase;
    }

    .timer {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      overflow: hidden;
      border: 1px solid rgba(121, 80, 56, 0.22);
      border-radius: 0.58rem;
      background: rgba(245, 227, 198, 0.5);
    }

    .time-unit {
      padding: 1.16rem 0.28rem 0.98rem;
      text-align: center;
    }

    .time-unit + .time-unit { border-left: 1px solid rgba(121, 80, 56, 0.2); }

    .time-value {
      display: block;
      color: var(--brown);
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: clamp(1.7rem, 3.55vw, 2.62rem);
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      letter-spacing: -0.08em;
      line-height: 1;
    }

    .time-label {
      display: block;
      margin-top: 0.58rem;
      color: var(--olive);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.16em;
    }

    .card-footer {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.68rem;
      margin-top: 1.3rem;
      color: rgba(88, 65, 52, 0.78);
      font-size: 0.82rem;
      line-height: 1.75;
    }

    .live-message {
      display: none;
      margin-top: 1rem;
      padding: 0.95rem 1rem;
      border-left: 2px solid var(--terracotta);
      background: rgba(186, 124, 77, 0.1);
      color: var(--brown);
      font-weight: 700;
      letter-spacing: 0.05em;
      line-height: 1.75;
    }

    .action-panel {
      position: relative;
      z-index: 4;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.7rem;
      margin-top: 1rem;
      padding: 0.85rem;
      border: 1px solid rgba(94, 63, 45, 0.24);
      border-radius: 0.78rem;
      background: rgba(84, 57, 43, 0.9);
      box-shadow: var(--shadow-soft);
    }

    .button,
    .calendar-summary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.42rem;
      min-height: 2.78rem;
      padding: 0.66rem 0.92rem;
      border: 1px solid transparent;
      border-radius: 0.42rem;
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.075em;
      text-decoration: none;
      text-transform: uppercase;
      transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
      cursor: pointer;
    }

    .button:hover,
    .calendar-summary:hover { transform: translateY(-2px); }

    .button:active,
    .calendar-summary:active { transform: translateY(0); }

    .button-primary {
      color: #3c2f26;
      background: var(--honey-soft);
    }

    .button-secondary,
    .calendar-summary {
      color: var(--paper);
      border-color: rgba(250, 228, 185, 0.34);
      background: rgba(255, 250, 242, 0.06);
    }

    .calendar-wrap { position: relative; }
    .calendar-wrap summary { list-style: none; }
    .calendar-wrap summary::-webkit-details-marker { display: none; }

    .calendar-menu {
      position: absolute;
      left: 0;
      bottom: calc(100% + 0.55rem);
      width: min(21rem, calc(100vw - 2.2rem));
      padding: 0.52rem;
      border: 1px solid rgba(117, 75, 51, 0.24);
      border-radius: 0.7rem;
      background: rgba(255, 250, 242, 0.98);
      box-shadow: var(--shadow);
    }

    .calendar-option {
      display: block;
      width: 100%;
      padding: 0.78rem 0.82rem;
      border: 0;
      border-radius: 0.46rem;
      color: var(--brown);
      background: transparent;
      text-align: left;
      cursor: pointer;
      transition: background 160ms ease;
    }

    .calendar-option:hover { background: rgba(229, 202, 155, 0.38); }

    .calendar-option strong,
    .calendar-option span { display: block; }

    .calendar-option strong {
      font-size: 0.9rem;
      letter-spacing: 0.04em;
    }

    .calendar-option span {
      margin-top: 0.24rem;
      color: var(--olive);
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: 0.67rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      line-height: 1.55;
      text-transform: uppercase;
    }

    .details {
      display: grid;
      grid-template-columns: 1.08fr 0.92fr;
      gap: 1rem;
      margin-top: 1rem;
    }

    .detail-card {
      position: relative;
      overflow: hidden;
      padding: 1.5rem 1.55rem;
      border: 1px solid rgba(113, 75, 51, 0.2);
      border-radius: 0.86rem;
      background: rgba(255, 250, 242, 0.91);
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(12px);
    }

    .detail-card::before {
      content: "";
      position: absolute;
      inset: 0 auto 0 0;
      width: 0.28rem;
      background: linear-gradient(180deg, var(--terracotta), var(--honey));
    }

    .detail-card h3 {
      margin: 0 0 1rem;
      color: var(--terracotta);
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: 0.73rem;
      letter-spacing: 0.18em;
      line-height: 1.6;
      text-transform: uppercase;
    }

    .detail-card h3 span {
      display: block;
      margin-top: 0.28rem;
      color: var(--brown);
      font-family: "Iowan Old Style", "Noto Serif TC", "Songti TC", "PingFang TC", serif;
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: 0.09em;
      text-transform: none;
    }

    .detail-card ul {
      display: grid;
      gap: 0.62rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .detail-card li {
      display: grid;
      grid-template-columns: 5.5rem 1fr;
      gap: 0.68rem;
      color: rgba(79, 59, 48, 0.86);
      font-size: 0.88rem;
      line-height: 1.7;
    }

    .detail-card li strong {
      color: var(--brown);
      font-weight: 700;
    }

    .wind-card {
      border-color: rgba(80, 56, 44, 0.3);
      background: linear-gradient(145deg, rgba(88, 60, 45, 0.96), rgba(66, 49, 39, 0.96));
    }

    .wind-card::before { background: linear-gradient(180deg, var(--honey-soft), var(--ochre)); }
    .wind-card h3 { color: var(--honey-soft); }
    .wind-card h3 span { color: var(--paper); }

    .tip {
      margin: 0;
      color: rgba(255, 246, 225, 0.84);
      font-size: 0.9rem;
      letter-spacing: 0.04em;
      line-height: 1.95;
    }

    .tip strong { color: var(--honey-soft); }

    .wind-signoff {
      display: block;
      margin-top: 1rem;
      color: rgba(238, 209, 158, 0.82);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
    }

    footer {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 1.4rem 0 0;
      color: rgba(73, 51, 40, 0.76);
      font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      font-size: 0.62rem;
      letter-spacing: 0.08em;
      line-height: 1.8;
      text-transform: uppercase;
    }

    .copyright {
      display: block;
      margin-top: 0.08rem;
      letter-spacing: 0.06em;
      text-transform: none;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 1.25rem;
      z-index: 20;
      max-width: min(92vw, 34rem);
      padding: 0.78rem 1rem;
      border: 1px solid rgba(255, 231, 188, 0.22);
      border-radius: 999px;
      color: var(--paper);
      background: rgba(58, 45, 37, 0.95);
      box-shadow: var(--shadow);
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      line-height: 1.55;
      text-align: center;
      opacity: 0;
      pointer-events: none;
      transform: translate(-50%, 0.7rem);
      transition: opacity 180ms ease, transform 180ms ease;
    }

    .toast.is-visible {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    .fade-in { animation: rise 720ms both cubic-bezier(.2,.75,.25,1); }
    .delay-1 { animation-delay: 100ms; }
    .delay-2 { animation-delay: 190ms; }
    .delay-3 { animation-delay: 280ms; }

    @keyframes rise {
      from { opacity: 0; transform: translateY(15px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 860px) {
      main { padding-top: 1.3rem; }
      .hero { grid-template-columns: 1fr; padding-top: 5.1rem; }
      .hero-note { max-width: 22rem; }
      .countdown-grid, .details { grid-template-columns: 1fr; }
    }

    @media (max-width: 520px) {
      main { width: min(100% - 1.1rem, 1120px); }
      .topbar { align-items: flex-start; font-size: 0.56rem; }
      .hero { gap: 1.35rem; padding: 4.25rem 0 2.65rem; }
      .title-main { font-size: clamp(4rem, 21vw, 5.25rem); }
      .title-sub { margin-top: 0.43em; font-size: clamp(1.95rem, 13vw, 3.28rem); }
      .subtitle { font-size: 0.66rem; }
      .hero-note { font-size: 0.8rem; }
      .countdown-card { min-height: auto; padding: 1.12rem; }
      .timer { grid-template-columns: repeat(4, minmax(0, 1fr)); }
      .time-unit { padding: 0.92rem 0.1rem 0.78rem; }
      .time-value { font-size: clamp(1.43rem, 8vw, 2rem); }
      .time-label { font-size: 0.55rem; letter-spacing: 0.08em; }
      .action-panel { align-items: stretch; }
      .button, .calendar-wrap, .calendar-summary { width: 100%; }
      .detail-card li { grid-template-columns: 4.5rem 1fr; font-size: 0.83rem; }
      footer { display: block; }
      footer #updatedAt { display: block; margin-top: 0.28rem; }
      .toast { width: calc(100% - 1.4rem); border-radius: 0.8rem; }
    }
  </style>
</head>
<body>
  <main>
    <header class="topbar fade-in">
      <span>Fujii Kaze · Prema World Tour</span>
      <span>Kaohsiung · 2026</span>
    </header>

    <section class="hero fade-in delay-1">
      <div>
        <p class="eyebrow">Global First Stop</p>
        <h1>
          <span class="title-main">藤井風</span>
          <span class="title-sub">高雄演唱會</span>
        </h1>
        <p class="subtitle">Fujii Kaze Prema World Tour — Kaohsiung</p>
      </div>
      <p class="hero-note">Prema, don't you know that you are love itself?<br />You are love itself.</p>
    </section>

    <section class="countdown-grid" aria-label="演唱會倒數">
      <article class="countdown-card fade-in delay-2" data-target="ticket">
        <div class="card-kicker"><span class="status-dot"></span> Ticket Sale Countdown</div>
        <h2>距離公開售票</h2>
        <p class="datetime">2026.06.20 SAT · 12:00 PM · TAIPEI TIME</p>
        <div class="timer" aria-live="polite">
          <div class="time-unit"><span class="time-value" data-unit="days">00</span><span class="time-label">天</span></div>
          <div class="time-unit"><span class="time-value" data-unit="hours">00</span><span class="time-label">時</span></div>
          <div class="time-unit"><span class="time-value" data-unit="minutes">00</span><span class="time-label">分</span></div>
          <div class="time-unit"><span class="time-value" data-unit="seconds">00</span><span class="time-label">秒</span></div>
        </div>
        <div class="live-message" data-live-message>公開售票已開始。祝你手速如風。</div>
        <div class="card-footer">
          <span>KKTIX、全家便利商店 FamiPort</span>
          <span>每位 KKTIX 會員限購 4 張</span>
        </div>
      </article>

      <article class="countdown-card fade-in delay-3" data-target="concert">
        <div class="card-kicker"><span class="status-dot"></span> Concert Countdown</div>
        <h2>距離高雄相見</h2>
        <p class="datetime">2026.10.31 SAT · 07:00 PM · KAOHSIUNG</p>
        <div class="timer" aria-live="polite">
          <div class="time-unit"><span class="time-value" data-unit="days">00</span><span class="time-label">天</span></div>
          <div class="time-unit"><span class="time-value" data-unit="hours">00</span><span class="time-label">時</span></div>
          <div class="time-unit"><span class="time-value" data-unit="minutes">00</span><span class="time-label">分</span></div>
          <div class="time-unit"><span class="time-value" data-unit="seconds">00</span><span class="time-label">秒</span></div>
        </div>
        <div class="live-message" data-live-message>演出時間到了。讓風抵達現場。</div>
        <div class="card-footer">
          <span>高雄國家體育場</span>
          <span>高雄市左營區世運大道 100 號</span>
        </div>
      </article>
    </section>

    <section class="action-panel fade-in delay-3" aria-label="相關功能與連結">
      <a class="button button-primary" href="https://kktix.com/events/34473ba4/registrations/new" target="_blank" rel="noopener noreferrer">前往 KKTIX 搶票 ↗</a>
      <a class="button button-secondary" href="https://kklivetw.kktix.cc/events/34473ba4" target="_blank" rel="noopener noreferrer">查看官方節目資訊 ↗</a>
      <details class="calendar-wrap" id="calendarMenu">
        <summary class="calendar-summary">加入行事曆 ↓</summary>
        <div class="calendar-menu" role="menu" aria-label="選擇要加入行事曆的時間">
          <button class="calendar-option" type="button" data-calendar-key="ticket" role="menuitem">
            <strong>加入公開售票提醒</strong>
            <span>2026.06.20 SAT · 12:00 PM</span>
          </button>
          <button class="calendar-option" type="button" data-calendar-key="concert" role="menuitem">
            <strong>加入演唱會行程</strong>
            <span>2026.10.31 SAT · 07:00 PM</span>
          </button>
        </div>
      </details>
      <button class="button button-secondary" type="button" id="shareBtn">分享倒數</button>
    </section>

    <section class="details fade-in delay-3">
      <article class="detail-card ticket-info-card">
        <h3>Event Notes<span>票務資訊</span></h3>
        <ul>
          <li><strong>演出日期</strong><span>2026 年 10 月 31 日（六）19:00</span></li>
          <li><strong>演出地點</strong><span>高雄國家體育場（世運主場館）</span></li>
          <li><strong>公開售票</strong><span>2026 年 6 月 20 日（六）中午 12:00</span></li>
          <li><strong>票價</strong><span>NT$5,800 / 4,800 / 3,800 / 2,800 / 1,800，全場座席</span></li>
        </ul>
      </article>
      <article class="detail-card wind-card">
        <h3>Before The Wind Arrives<span>在風抵達之前</span></h3>
        <p class="tip"><strong>搶票提醒：</strong>先完成 KKTIX 會員、手機號碼與電子郵件驗證。啟售當天不建議同時開啟多個裝置、瀏覽器或分頁，以免購票流程異常。</p>
        <span class="wind-signoff">準備好，再讓好運順著風來。</span>
      </article>
    </section>

    <footer>
      <div>
        <span>Unofficial countdown page · Event information linked to KKLIVE / KKTIX</span>
        <span class="copyright">copyright / akira1989720</span>
      </div>
      <span id="updatedAt"></span>
    </footer>
  </main>

  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <script>
    const events = {
      ticket: new Date('2026-06-20T12:00:00+08:00'),
      concert: new Date('2026-10-31T19:00:00+08:00')
    };

    const calendarEvents = {
      ticket: {
        uid: 'fujii-kaze-kaohsiung-ticket-sale-20260620@akira1989720',
        filename: 'fujii-kaze-kaohsiung-ticket-sale-reminder.ics',
        startUtc: '20260620T040000Z',
        endUtc: '20260620T043000Z',
        summary: '藤井風高雄演唱會｜公開售票提醒',
        location: 'KKTIX 線上售票',
        description: 'Fujii Kaze Prema World Tour 高雄場公開售票。售票平台：KKTIX、全家便利商店 FamiPort。'
      },
      concert: {
        uid: 'fujii-kaze-kaohsiung-concert-20261031@akira1989720',
        filename: 'fujii-kaze-kaohsiung-concert.ics',
        startUtc: '20261031T110000Z',
        endUtc: '20261031T140000Z',
        summary: '藤井風 Prema World Tour｜高雄場',
        location: '高雄國家體育場（高雄市左營區世運大道 100 號）',
        description: '藤井風 Fujii Kaze Prema World Tour 高雄場。'
      }
    };

    const pad = (value) => String(value).padStart(2, '0');

    function updateCard(card) {
      const key = card.dataset.target;
      const target = events[key];
      const distance = target - new Date();
      const timer = card.querySelector('.timer');
      const message = card.querySelector('[data-live-message]');

      if (distance <= 0) {
        timer.style.display = 'none';
        message.style.display = 'block';
        return;
      }

      timer.style.display = 'grid';
      message.style.display = 'none';

      const totalSeconds = Math.floor(distance / 1000);
      const days = Math.floor(totalSeconds / 86400);
      const hours = Math.floor((totalSeconds % 86400) / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;

      card.querySelector('[data-unit="days"]').textContent = pad(days);
      card.querySelector('[data-unit="hours"]').textContent = pad(hours);
      card.querySelector('[data-unit="minutes"]').textContent = pad(minutes);
      card.querySelector('[data-unit="seconds"]').textContent = pad(seconds);
    }

    function refreshCountdowns() {
      document.querySelectorAll('[data-target]').forEach(updateCard);
    }

    refreshCountdowns();
    setInterval(refreshCountdowns, 1000);

    document.getElementById('updatedAt').textContent =
      `Local clock · ${new Intl.DateTimeFormat('zh-TW', {
        timeZone: 'Asia/Taipei',
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit', hour12: false
      }).format(new Date())}`;

    function escapeICS(value) {
      return String(value)
        .replace(/\\/g, '\\\\')
        .replace(/\n/g, '\\n')
        .replace(/,/g, '\\,')
        .replace(/;/g, '\\;');
    }

    function createICS(event) {
      const stamp = new Date().toISOString().replace(/[-:]/g, '').replace(/\.\d{3}/, '');
      return [
        'BEGIN:VCALENDAR',
        'VERSION:2.0',
        'CALSCALE:GREGORIAN',
        'METHOD:PUBLISH',
        'PRODID:-//akira1989720//Fujii Kaze Kaohsiung Countdown//ZH-TW',
        'BEGIN:VEVENT',
        `UID:${event.uid}`,
        `DTSTAMP:${stamp}`,
        `DTSTART:${event.startUtc}`,
        `DTEND:${event.endUtc}`,
        `SUMMARY:${escapeICS(event.summary)}`,
        `LOCATION:${escapeICS(event.location)}`,
        `DESCRIPTION:${escapeICS(event.description)}`,
        'END:VEVENT',
        'END:VCALENDAR'
      ].join('\r\n');
    }

    function downloadCalendar(key) {
      const event = calendarEvents[key];
      if (!event) return;

      const blob = new Blob([createICS(event)], { type: 'text/calendar;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = url;
      anchor.download = event.filename;
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
      document.getElementById('calendarMenu').open = false;
      showToast(key === 'ticket' ? '已下載公開售票提醒，可開啟檔案加入行事曆。' : '已下載演唱會行程，可開啟檔案加入行事曆。');
    }

    document.querySelectorAll('[data-calendar-key]').forEach((button) => {
      button.addEventListener('click', () => downloadCalendar(button.dataset.calendarKey));
    });

    document.addEventListener('click', (event) => {
      const menu = document.getElementById('calendarMenu');
      if (menu.open && !menu.contains(event.target)) menu.open = false;
    });

    let toastTimer;
    function showToast(message) {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.classList.add('is-visible');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('is-visible'), 3300);
    }

    async function copyText(text) {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return;
      }

      const input = document.createElement('textarea');
      input.value = text;
      input.setAttribute('readonly', '');
      input.style.position = 'fixed';
      input.style.opacity = '0';
      document.body.appendChild(input);
      input.select();
      const copied = document.execCommand('copy');
      input.remove();
      if (!copied) throw new Error('Copy command was not available.');
    }

    document.getElementById('shareBtn').addEventListener('click', async () => {
      const isPublishedPage = /^https?:$/.test(window.location.protocol);
      const shareText = '藤井風高雄演唱會倒數｜公開售票：2026.06.20 12:00｜演出：2026.10.31 19:00';
      const shareData = {
        title: '藤井風高雄演唱會倒數',
        text: shareText,
        ...(isPublishedPage ? { url: window.location.href } : {})
      };
      const copiedText = isPublishedPage ? `${shareText}\n${window.location.href}` : shareText;

      try {
        if (navigator.share && isPublishedPage) {
          await navigator.share(shareData);
          showToast('已開啟分享選單。');
          return;
        }

        await copyText(copiedText);
        showToast(isPublishedPage
          ? '倒數頁網址已複製，可以貼給朋友了。'
          : '目前是本機預覽：已複製活動資訊。上線後即可分享公開網址。');
      } catch (error) {
        if (error.name !== 'AbortError') {
          showToast('暫時無法自動分享，請手動複製瀏覽器網址。');
        }
      }
    });
  </script>
</body>
</html>
